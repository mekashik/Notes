<?xml version="1.0" encoding="utf-8" ?>
<Application xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:Notes"
             xmlns:conv="clr-namespace:Notes.Helpers"
             x:Class="Notes.App">
    <Application.Resources>
        <ResourceDictionary>

            <conv:FavoriteIconConverter x:Key="FavoriteIconConverter"/>

            <!-- ЦВЕТА ИЗ ИКОНКИ ПРИЛОЖЕНИЯ -->
            <!-- Основные цвета градиента иконки -->
            <Color x:Key="AeroTeal">#6affca</Color>
            <Color x:Key="AeroLightBlue">#99d7e9</Color>
            <Color x:Key="PrimaryBlue">#0099FF</Color>
            <Color x:Key="LightBlue">#66CCFF</Color>
            <Color x:Key="VeryLightBlue">#E6F7FF</Color>

            <!-- Дополнительные цвета для градиентов -->
            <Color x:Key="CardGradientTop">#4DB8FF</Color>
            <Color x:Key="CardGradientBottom">#0099FF</Color>
            <Color x:Key="AccentCyan">#6affca</Color>

            <!-- ГЛОБАЛЬНЫЕ СТИЛИ -->
            <Style TargetType="ContentPage">
                <Setter Property="BackgroundColor"
                    Value="{AppThemeBinding Light=#FFFFFF, Dark=#0F1419}" />
            </Style>

            <Style TargetType="Label">
                <Setter Property="TextColor"
                    Value="{AppThemeBinding Light=#1A1A1A, Dark=#FFFFFF}" />
                <Setter Property="FontFamily" Value="PlayRegular" />
            </Style>

            <Style TargetType="Entry">
                <Setter Property="TextColor"
                    Value="{AppThemeBinding Light=#1A1A1A, Dark=#FFFFFF}" />
                <Setter Property="PlaceholderColor"
                    Value="{AppThemeBinding Light=#999999, Dark=#666666}" />
                <Setter Property="BackgroundColor"
                    Value="{AppThemeBinding Light=#F5F5F5, Dark=#1E2328}" />
                <Setter Property="FontFamily" Value="PlayRegular" />
            </Style>

            <Style TargetType="Editor">
                <Setter Property="TextColor"
                    Value="{AppThemeBinding Light=#1A1A1A, Dark=#FFFFFF}" />
                <Setter Property="PlaceholderColor"
                    Value="{AppThemeBinding Light=#999999, Dark=#666666}" />
                <Setter Property="BackgroundColor"
                    Value="{AppThemeBinding Light=#F5F5F5, Dark=#1E2328}" />
                <Setter Property="FontFamily" Value="PlayRegular" />
            </Style>

            <Style TargetType="Button">
                <Setter Property="TextColor" Value="White"/>
                <Setter Property="FontFamily" Value="PlayBold"/>
                <Setter Property="BackgroundColor" Value="{StaticResource PrimaryBlue}"/>
                <Setter Property="Padding" Value="14,10"/>
                <Setter Property="CornerRadius" Value="12"/>
            </Style>

            <Style TargetType="Picker">
                <Setter Property="TextColor"
                    Value="{AppThemeBinding Light=#1A1A1A, Dark=#FFFFFF}" />
                <Setter Property="BackgroundColor"
                    Value="{AppThemeBinding Light=#F5F5F5, Dark=#1E2328}" />
                <Setter Property="TitleColor"
                    Value="{AppThemeBinding Light=#666666, Dark=#AAAAAA}" />
                <Setter Property="FontFamily" Value="PlayRegular" />
            </Style>

            <Style TargetType="SearchBar">
                <Setter Property="TextColor"
                    Value="{AppThemeBinding Light=#1A1A1A, Dark=#FFFFFF}" />
                <Setter Property="PlaceholderColor"
                    Value="{AppThemeBinding Light=#999999, Dark=#666666}" />
                <Setter Property="BackgroundColor"
                    Value="{AppThemeBinding Light=#F5F5F5, Dark=#1E2328}" />
                <Setter Property="CancelButtonColor"
                    Value="{StaticResource PrimaryBlue}" />
                <Setter Property="FontFamily" Value="PlayRegular" />
            </Style>

        </ResourceDictionary>
    </Application.Resources>
</Application>