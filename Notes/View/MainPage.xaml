<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Notes.MainPage"
             Title="Заметки"
             BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#0F1419}"
             Shell.TitleColor="{AppThemeBinding Light=#FFFFFF, Dark=#66CCFF}"
Shell.BackgroundColor="{AppThemeBinding Light=#0099FF, Dark=#0F1419}">

    <Grid RowDefinitions="Auto,*" Padding="0" RowSpacing="0">

        <!-- SearchBar с фоном -->
        <Frame Grid.Row="0"
               Padding="0"
               Margin="0"
               CornerRadius="0"
               BorderColor="Transparent"
               BackgroundColor="{AppThemeBinding Light=#F5F5F5, Dark=#1E2328}">
            <SearchBar x:Name="SearchBar"
                       Placeholder="Поиск заметок..."
                       TextChanged="OnSearchChanged"
                       BackgroundColor="Transparent"
                       CancelButtonColor="#0099FF"
                       Margin="0"/>
        </Frame>

        <!-- CollectionView с скроллом и FAB -->
        <Grid Grid.Row="1" RowDefinitions="*" ColumnDefinitions="*">
            <ScrollView Grid.Row="0" Grid.Column="0">
                <Grid RowDefinitions="*" ColumnDefinitions="*">
                    <CollectionView x:Name="NotesCollection"
                                    Grid.Row="0"
                                    SelectionMode="None">
                        <CollectionView.ItemsLayout>
                            <LinearItemsLayout Orientation="Vertical"
                                             ItemSpacing="8"/>
                        </CollectionView.ItemsLayout>
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <SwipeView Margin="12,0,12,0">
                                    <SwipeView.RightItems>
                                        <SwipeItems Mode="Execute">
                                            <SwipeItem Text="Удалить"
                                               BackgroundColor="#FF6B6B"
                                               Invoked="OnDeleteNote"/>
                                        </SwipeItems>
                                    </SwipeView.RightItems>

                                    <Frame CornerRadius="16"
                                           Padding="12"
                                           BorderColor="#66CCFF"
                                           HasShadow="True"
                                           BackgroundColor="{AppThemeBinding Light=#F0F8FF, Dark=#1E3A5F}">
                                        <Frame.GestureRecognizers>
                                            <TapGestureRecognizer Tapped="OnNoteTapped"/>
                                        </Frame.GestureRecognizers>

                                        <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="8">
                                            <!-- Звезда -->
                                            <ImageButton Grid.Column="0"
                                                 Source="{Binding IsFavorite, Converter={StaticResource FavoriteIconConverter}}"
                                                 WidthRequest="28"
                                                 HeightRequest="28"
                                                 HorizontalOptions="Start"
                                                 VerticalOptions="Start"
                                                 Clicked="OnFavoriteClicked"
                                                 BackgroundColor="Transparent"/>

                                            <!-- Текст в центре -->
                                            <Label Grid.Column="1"
                                                   Text="{Binding DisplayTitle}"
                                                   TextColor="{AppThemeBinding Light=#1A1A1A, Dark=#FFFFFF}"
                                                   FontSize="15"
                                                   FontAttributes="Bold"
                                                   LineBreakMode="TailTruncation"
                                                   MaxLines="2"
                                                   VerticalTextAlignment="Center"/>

                                            <!-- Дата -->
                                            <Label Grid.Column="2"
                                                   Text="{Binding CreatedAt, StringFormat='{0:d}'}"
                                                   TextColor="{AppThemeBinding Light=#999999, Dark=#AAAAAA}"
                                                   FontSize="12"
                                                   HorizontalOptions="End"
                                                   VerticalTextAlignment="Center"/>
                                        </Grid>
                                    </Frame>
                                </SwipeView>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>

                    <!-- Пустое состояние -->
                    <StackLayout Grid.Row="0"
                                 x:Name="EmptyNotesStack"
                                 IsVisible="False"
                                 Padding="20"
                                 Spacing="10"
                                 VerticalOptions="CenterAndExpand"
                                 HorizontalOptions="CenterAndExpand">
                        <Label Text="Нет заметок"
                               FontSize="18"
                               FontAttributes="Bold"
                               TextColor="{AppThemeBinding Light=#1A1A1A, Dark=#FFFFFF}"
                               HorizontalOptions="Center"/>
                        <Label Text="Нажмите на кнопку чтобы создать новую заметку"
                               FontSize="14"
                               TextColor="{AppThemeBinding Light=#666666, Dark=#AAAAAA}"
                               HorizontalOptions="Center"
                               HorizontalTextAlignment="Center"/>
                    </StackLayout>
                </Grid>
            </ScrollView>

            <!-- Добавить заметку -->
            <Button Grid.Row="0"
                    Grid.Column="0"
                    Text="+"
                    FontSize="32"
                    FontAttributes="Bold"
                    WidthRequest="70"
                    HeightRequest="70"
                    CornerRadius="35"
                    BackgroundColor="#0099FF"
                    TextColor="White"
                    Clicked="OnAddClicked"
                    HorizontalOptions="End"
                    VerticalOptions="End"
                    Margin="0,0,20,20"
                    ZIndex="10"/>
        </Grid>

    </Grid>

</ContentPage>